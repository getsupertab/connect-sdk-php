# Supertab Connect PHP SDK Demo Configuration
# Copy to .env and fill in your values.
#
# This file is only needed for "composer demo" (real API mode).
# "composer demo:local" runs self-contained and ignores this file.

# The protected resource URL to access (must be an RSL-protected site)
RESOURCE_URL=https://example.com/article

# Bot client credentials (from your Supertab Connect dashboard)
SUPERTAB_CLIENT_ID=
SUPERTAB_CLIENT_SECRET=
